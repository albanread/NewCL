/target/

# Release package — built artefacts, never source.
/release/

# Scratch / temp directories.
/tmp/

# Local debug / phase-dump artifacts produced by the driver and tests.
# Useful while iterating, never committed.
*.log
*.ll
/out.log
/out.txt

# Captured stdout/stderr from test runs.
ncl-stdout*.txt
ncl-stderr*.txt

# Loader artifact cache (non-canonical, see MANIFESTO.md). Source is
# canonical; the cache can be deleted at any time without loss.
/.ncl-cache/
